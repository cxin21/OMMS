{
  "id": "omms",
  "kind": "memory",
  "name": "OMMS Memory System",
  "description": "Intelligent memory management with vector search, user profiles, and knowledge graphs for OpenClaw",
  "version": "3.5.0",
  "author": "cxin21",
  "license": "MIT",
  "homepage": "https://github.com/omms-team/openclaw-omms",
  "repository": "https://github.com/omms-team/openclaw-omms",
  "bugs": "https://github.com/omms-team/openclaw-omms/issues",
  "keywords": ["openclaw", "memory", "vector", "ai", "agent"],
  "engines": {
    "openclaw": ">=2026.3.24"
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "enableAutoCapture": {
        "type": "boolean",
        "default": true,
        "description": "Automatically capture important content from conversations"
      },
      "enableAutoRecall": {
        "type": "boolean",
        "default": true,
        "description": "Automatically inject relevant memories before prompt build"
      },
      "enableLLMExtraction": {
        "type": "boolean",
        "default": true,
        "description": "Use LLM for memory extraction (more accurate, requires LLM API)"
      },
      "enableGraphEngine": {
        "type": "boolean",
        "default": false,
        "description": "Enable knowledge graph for relationship tracking"
      },
      "enableProfile": {
        "type": "boolean",
        "default": true,
        "description": "Build and maintain user profiles"
      },
      "enableVectorSearch": {
        "type": "boolean",
        "default": true,
        "description": "Enable semantic vector search (requires embedding provider)"
      },
      "maxMemoriesPerSession": {
        "type": "number",
        "default": 50,
        "description": "Maximum memories to capture per session"
      },
      "webUiPort": {
        "type": "number",
        "default": 3456,
        "description": "Web UI server port (default: 3456)"
      },
      "llm": {
        "type": "object",
        "description": "LLM service configuration for memory extraction",
        "properties": {
          "provider": {
            "type": "string",
            "default": "openai-compatible",
            "description": "LLM provider (e.g., openai-compatible, minimax)"
          },
          "model": {
            "type": "string",
            "default": "abab6.5s-chat",
            "description": "LLM model name for extraction"
          },
          "baseURL": {
            "type": "string",
            "default": "https://api.minimax.chat/v1",
            "description": "LLM API base URL"
          },
          "apiKey": {
            "type": "string",
            "description": "LLM API key"
          }
        },
        "required": ["baseURL", "apiKey", "model"]
      },
      "embedding": {
        "type": "object",
        "description": "Embedding service configuration (OpenAI-compatible API)",
        "properties": {
          "model": {
            "type": "string",
            "default": "BAAI/bge-m3",
            "description": "Embedding model name (e.g., BAAI/bge-m3, text-embedding-3-small)"
          },
          "dimensions": {
            "type": "number",
            "default": 1024,
            "description": "Embedding vector dimensions (1024 for BGE-M3, 1536 for OpenAI)"
          },
          "baseURL": {
            "type": "string",
            "default": "https://api.siliconflow.cn/v1",
            "description": "API base URL (e.g., https://api.siliconflow.cn/v1)"
          },
          "apiKey": {
            "type": "string",
            "description": "API key for the embedding service"
          }
        },
        "required": ["baseURL", "apiKey", "model"]
      },
      "search": {
        "type": "object",
        "description": "Search configuration",
        "properties": {
          "vectorWeight": {
            "type": "number",
            "default": 0.7,
            "description": "Weight for vector search results (0-1)"
          },
          "keywordWeight": {
            "type": "number",
            "default": 0.3,
            "description": "Weight for keyword search results (0-1)"
          },
          "limit": {
            "type": "number",
            "default": 10,
            "description": "Maximum search results"
          }
        }
      },
      "logging": {
        "type": "object",
        "description": "Logging configuration",
        "properties": {
          "level": {
            "type": "string",
            "default": "info",
            "enum": ["debug", "info", "warn", "error"],
            "description": "Global log level"
          },
          "output": {
            "type": "string",
            "default": "console",
            "enum": ["console", "file", "both"],
            "description": "Log output destination"
          },
          "filePath": {
            "type": "string",
            "description": "Log file path (required if output is file/both)"
          }
        }
      },
      "scopeUpgrade": {
        "type": "object",
        "description": "Memory scope upgrade configuration (controls when memories expand to wider scopes)",
        "properties": {
          "agentThreshold": {
            "type": "number",
            "default": 0.3,
            "description": "Scope score threshold to upgrade to agent scope"
          },
          "globalThreshold": {
            "type": "number",
            "default": 0.6,
            "description": "Scope score threshold to upgrade to global scope"
          },
          "minRecallCount": {
            "type": "number",
            "default": 2,
            "description": "Minimum recall count before scope upgrade"
          },
          "minAgentCount": {
            "type": "number",
            "default": 2,
            "description": "Minimum number of different agents using the memory before global upgrade"
          }
        }
      },
      "forgetPolicy": {
        "type": "object",
        "description": "Memory forget/archive policy configuration",
        "properties": {
          "archiveThreshold": {
            "type": "number",
            "default": 0.2,
            "description": "Importance below this triggers archive check"
          },
          "archiveDays": {
            "type": "number",
            "default": 30,
            "description": "Days since last access to trigger archive"
          },
          "archiveUpdateDays": {
            "type": "number",
            "default": 14,
            "description": "Days since last update to trigger archive (secondary condition)"
          },
          "deleteThreshold": {
            "type": "number",
            "default": 0.1,
            "description": "Importance below this triggers delete check"
          },
          "deleteDays": {
            "type": "number",
            "default": 180,
            "description": "Days since last update to trigger delete"
          }
        }
      },
      "boostPolicy": {
        "type": "object",
        "description": "Memory importance boost policy on recall",
        "properties": {
          "boostEnabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable automatic importance boost on recall"
          },
          "lowBoost": {
            "type": "number",
            "default": 0.1,
            "description": "Boost amount for importance < 0.3"
          },
          "mediumBoost": {
            "type": "number",
            "default": 0.08,
            "description": "Boost amount for importance 0.3-0.5"
          },
          "highBoost": {
            "type": "number",
            "default": 0.05,
            "description": "Boost amount for importance 0.5-0.8"
          },
          "maxImportance": {
            "type": "number",
            "default": 1.0,
            "description": "Maximum importance value (capped)"
          }
        }
      },
      "recall": {
        "type": "object",
        "description": "Memory recall configuration",
        "properties": {
          "autoRecallLimit": {
            "type": "number",
            "default": 5,
            "description": "Number of memories to auto-recall before prompt build"
          },
          "manualRecallLimit": {
            "type": "number",
            "default": 10,
            "description": "Default limit for manual recall tool"
          },
          "minSimilarity": {
            "type": "number",
            "default": 0.5,
            "description": "Minimum similarity score to include in results"
          },
          "boostOnRecall": {
            "type": "boolean",
            "default": true,
            "description": "Boost memory importance on recall"
          },
          "boostScopeScoreOnRecall": {
            "type": "boolean",
            "default": true,
            "description": "Boost scope score on recall"
          }
        }
      },
      "dreaming": {
        "type": "object",
        "description": "Dreaming mechanism configuration (experimental)",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Whether to enable the Dreaming mechanism"
          },
          "schedule": {
            "type": "object",
            "description": "Scheduled trigger configuration",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether to enable scheduled triggering"
              },
              "time": {
                "type": "string",
                "default": "02:00",
                "description": "Daily trigger time (HH:MM format)"
              },
              "timezone": {
                "type": "string",
                "default": "Asia/Shanghai",
                "description": "Timezone for scheduled trigger"
              }
            }
          },
          "memoryThreshold": {
            "type": "object",
            "description": "Memory threshold trigger configuration",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether to enable memory threshold triggering"
              },
              "minMemories": {
                "type": "number",
                "default": 50,
                "description": "Minimum number of memories to trigger"
              },
              "maxAgeHours": {
                "type": "number",
                "default": 24,
                "description": "Maximum memory age in hours"
              }
            }
          },
          "sessionTrigger": {
            "type": "object",
            "description": "Session count trigger configuration",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether to enable session count triggering"
              },
              "afterSessions": {
                "type": "number",
                "default": 10,
                "description": "Number of sessions after which to trigger"
              }
            }
          },
          "promotion": {
            "type": "object",
            "description": "Memory promotion configuration",
            "properties": {
              "minScore": {
                "type": "number",
                "default": 0.7,
                "description": "Minimum score for memory promotion"
              },
              "weights": {
                "type": "object",
                "description": "Promotion score weights",
                "properties": {
                  "recallFrequency": {
                    "type": "number",
                    "default": 0.25,
                    "description": "Recall frequency weight"
                  },
                  "relevance": {
                    "type": "number",
                    "default": 0.20,
                    "description": "Relevance weight"
                  },
                  "diversity": {
                    "type": "number",
                    "default": 0.15,
                    "description": "Diversity weight"
                  },
                  "recency": {
                    "type": "number",
                    "default": 0.15,
                    "description": "Recency weight"
                  },
                  "consolidation": {
                    "type": "number",
                    "default": 0.15,
                    "description": "Consolidation weight"
                  },
                  "conceptualRichness": {
                    "type": "number",
                    "default": 0.10,
                    "description": "Conceptual richness weight"
                  }
                }
              }
            }
          },
          "output": {
            "type": "object",
            "description": "Output configuration",
            "properties": {
              "path": {
                "type": "string",
                "default": "~/.openclaw/memory/DREAMS.md",
                "description": "Path to DREAMS.md file"
              },
              "maxReflections": {
                "type": "number",
                "default": 5,
                "description": "Maximum number of reflections per run"
              },
              "maxThemes": {
                "type": "number",
                "default": 10,
                "description": "Maximum number of themes per run"
              }
            }
          },
          "logging": {
            "type": "object",
            "description": "Logging configuration",
            "properties": {
              "level": {
                "type": "string",
                "default": "info",
                "description": "Log level",
                "enum": ["debug", "info", "warn", "error"]
              },
              "consoleOutput": {
                "type": "boolean",
                "default": true,
                "description": "Whether to output logs to console"
              },
              "fileOutput": {
                "type": "boolean",
                "default": true,
                "description": "Whether to output logs to file"
              },
              "outputPath": {
                "type": "string",
                "default": "~/.openclaw/omms-dreaming.log",
                "description": "Path to log file"
              },
              "maxFileSize": {
                "type": "string",
                "default": "10MB",
                "description": "Maximum log file size"
              },
              "maxFiles": {
                "type": "number",
                "default": 5,
                "description": "Maximum number of log files to keep"
              }
            }
          }
        }
      }
    },
    "additionalProperties": true
  }
}
